{
	"compilerOptions": {
		"target": "ES2015",
		"lib": ["ES2015", "dom"],
		"module": "ES2015",
		"types": ["cypress", "node"],
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"noEmit": true,
		"noUncheckedIndexedAccess": true,
		"strict": true,
		"noImplicitAny": true,
		"skipLibCheck": true
	}
}
